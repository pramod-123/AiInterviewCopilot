{
  "name": "ai-interview-coach-server",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate",
    "prestart": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "rm -f data/app.db data/app.db-wal data/app.db-shm && rm -rf data/live-sessions && prisma db push",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "live-session:reset-post-process": "tsx scripts/reset-live-session-post-process.ts",
    "live-session:reprocess": "tsx scripts/reprocess-live-session.ts",
    "fixture:video:longest-substring": "tsx scripts/generate-synthetic-interview-video.ts",
    "db:seed:synthetic-live-session": "tsx scripts/seed-synthetic-live-session.ts",
    "test:agent-tools": "tsx scripts/test-agent-tools.ts",
    "test:single-agent-evaluator": "tsx scripts/test-single-agent-evaluator.ts",
    "test:single-agent-evaluator:providers": "tsx scripts/test-single-agent-evaluator-providers.ts",
    "compare-evaluators": "tsx scripts/compare-evaluators.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.48.0",
    "@langchain/anthropic": "^0.3.15",
    "@langchain/core": "^0.3.40",
    "@langchain/google-genai": "^0.1.12",
    "@langchain/ollama": "^0.2.1",
    "@langchain/openai": "^0.3.17",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "langchain": "^0.3.19",
    "openai": "^4.85.4",
    "pino": "^10.1.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "prisma": "^7.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.5"
  }
}
