{
  "name": "ai-interview-copilot-server",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:video-pipeline": "tsx src/video-pipeline/pipelineCli.ts video",
    "pipeline:e2e": "tsx src/video-pipeline/pipelineCli.ts e2e",
    "pipeline:e2e:stt-eval": "tsx src/video-pipeline/pipelineCli.ts stt-eval",
    "pipeline:e2e:finish": "tsx src/video-pipeline/pipelineCli.ts finish-e2e",
    "test:api:mov": "bash scripts/post-interview-mov.sh"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@prisma/client": "^6.3.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "openai": "^4.85.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "prisma": "^6.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.5"
  }
}
