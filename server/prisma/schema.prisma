generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  /// Single connection avoids SQLite writer lock contention across a pool (see P1008 / "database is locked").
  url      = "file:../data/app.db?connection_limit=1"
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// Where this timed text came from (mic/STT vs screen OCR).
enum TranscriptSource {
  AUDIO_STT
  VIDEO_OCR
}

model Job {
  id           String    @id @default(uuid())
  status       JobStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  /// When set, this job was spawned from a browser live session (tab capture + code snapshots).
  liveSessionId String?               @unique
  liveSession   InterviewLiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)

  interviewAudio      InterviewAudio?
  interviewVideo      InterviewVideo?
  transcriptSegments  TranscriptSegment[]
  result              Result?
}

/// Uploaded audio artifact (file on disk). Timed speech text lives in TranscriptSegment (source AUDIO_STT).
model InterviewAudio {
  id               String   @id @default(uuid())
  jobId            String   @unique
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  filePath         String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  durationSeconds  Float?
  createdAt        DateTime @default(now())
}

/// Uploaded interview recording (video). Full pipeline writes derived WAV under uploads/<jobId>/pipeline/audio.wav.
model InterviewVideo {
  id               String   @id @default(uuid())
  jobId            String   @unique
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  filePath         String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())
}

/// One row per caption line or OCR snippet; times are milliseconds from the start of the interview/session timeline.
model TranscriptSegment {
  id        String           @id @default(uuid())
  jobId     String
  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  source    TranscriptSource
  startMs   Int
  endMs     Int
  text      String
  sequence  Int              @default(0)
  createdAt DateTime         @default(now())

  @@index([jobId, source])
}

model Result {
  id        String   @id @default(uuid())
  jobId     String   @unique
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  payload   Json
  createdAt DateTime @default(now())
}

/// Browser extension live capture: screen chunks + periodic editor snapshots (e.g. LeetCode).
enum LiveSessionStatus {
  ACTIVE
  ENDED
}

model InterviewLiveSession {
  id        String            @id @default(uuid())
  status    LiveSessionStatus @default(ACTIVE)
  /// Problem statement / prompt scraped when recording starts (e.g. LeetCode).
  question  String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  videoChunks     LiveVideoChunk[]
  codeSnapshots   LiveCodeSnapshot[]
  postProcessJob  Job?
}

model LiveVideoChunk {
  id        String               @id @default(uuid())
  sessionId String
  session   InterviewLiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sequence  Int
  filePath  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime             @default(now())

  @@unique([sessionId, sequence])
  @@index([sessionId])
}

model LiveCodeSnapshot {
  id         String               @id @default(uuid())
  sessionId  String
  session    InterviewLiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sequence   Int
  code       String
  /// Seconds from the start of tab capture (t≈0 on merged recording / audio SRT timeline).
  offsetSeconds Float @default(0)
  capturedAt DateTime
  createdAt  DateTime             @default(now())

  @@unique([sessionId, sequence])
  @@index([sessionId])
}
