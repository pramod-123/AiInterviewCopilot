generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// Screen ROI OCR (uploaded video) vs browser editor capture (live session).
enum CodeSnapshotSource {
  VIDEO_OCR
  EDITOR_SNAPSHOT
}

model Job {
  id           String    @id @default(uuid())
  status       JobStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  /// When set, this job was spawned from a browser live session (tab capture + code snapshots).
  liveSessionId String?               @unique
  liveSession   InterviewLiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)

  interviewAudio   InterviewAudio?
  interviewVideo   InterviewVideo?
  /// STT segments (`startMs`–`endMs` speech windows).
  speechUtterances SpeechUtterance[]
  /// Point-in-time screen/editor text (`offsetMs` on the job timeline).
  codeSnapshots   CodeSnapshot[]
  result          Result?
}

/// Uploaded audio artifact (file on disk). Timed speech lives in {@link SpeechUtterance}.
model InterviewAudio {
  id               String   @id @default(uuid())
  jobId            String   @unique
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  filePath         String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  durationSeconds  Float?
  createdAt        DateTime @default(now())
}

/// Uploaded interview recording (video). Full pipeline writes derived WAV under uploads/<jobId>/pipeline/audio.wav.
model InterviewVideo {
  id               String   @id @default(uuid())
  jobId            String   @unique
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  filePath         String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())
}

model SpeechUtterance {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  startMs   Int
  endMs     Int
  text      String
  /// Best-effort speaker from diarization overlapping this STT window (e.g. INTERVIEWER, SPEAKER_00); null if unknown.
  speakerLabel String?
  sequence  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([jobId])
  @@map("speech_utterances")
}

model CodeSnapshot {
  id        String             @id @default(uuid())
  jobId     String
  job       Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  source    CodeSnapshotSource
  offsetMs  Int
  text      String
  sequence  Int                @default(0)
  createdAt DateTime           @default(now())

  @@index([jobId, source])
  @@map("code_snapshots")
}

model Result {
  id        String   @id @default(uuid())
  jobId     String   @unique
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  payload   Json
  createdAt DateTime @default(now())
}

/// Browser extension live capture: screen chunks + periodic editor snapshots (e.g. LeetCode).
enum LiveSessionStatus {
  ACTIVE
  ENDED
}

model InterviewLiveSession {
  id        String            @id @default(uuid())
  status    LiveSessionStatus @default(ACTIVE)
  /// Problem statement / prompt scraped when recording starts (e.g. LeetCode).
  question  String?
  /// When false, Gemini Live is not used; transcript is produced offline after session end (local/remote STT).
  liveInterviewerEnabled Boolean @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  videoChunks      LiveVideoChunk[]
  codeSnapshots    LiveCodeSnapshot[]
  postProcessJob   Job?
}

model LiveVideoChunk {
  id        String               @id @default(uuid())
  sessionId String
  session   InterviewLiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sequence  Int
  filePath  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime             @default(now())

  @@unique([sessionId, sequence])
  @@index([sessionId])
}

model LiveCodeSnapshot {
  id         String               @id @default(uuid())
  sessionId  String
  session    InterviewLiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sequence   Int
  code       String
  /// Seconds from the start of tab capture (t≈0 on merged recording / audio SRT timeline).
  offsetSeconds Float @default(0)
  capturedAt DateTime
  createdAt  DateTime             @default(now())

  @@unique([sessionId, sequence])
  @@index([sessionId])
}
