# Copy to .env and fill in values. Never commit .env.

# --- OpenAI (remote STT, vision ROI, OpenAI-backed evaluation) ---
OPENAI_API_KEY=
OPENAI_EVAL_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=whisper-1

# Optional: retry tuning for OpenAI STT HTTP client
# OPENAI_STT_MAX_RETRIES=
# OPENAI_STT_RETRY_BASE_MS=

# --- Anthropic (only if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_EVAL_MODEL=claude-3-5-haiku-20241022

# --- Providers ---
# STT: remote (default) | local — "none" is not allowed for the HTTP API
STT_PROVIDER=remote
# Evaluator: llm (one-shot JSON) | single-agent (LangChain tool agent)
EVALUATION_PROVIDER=single-agent
# App LLM vendor (evaluation, WhisperX speaker→role mapping, LlmClientFactory.create)
LLM_PROVIDER=openai
# Max tool+LLM turns for the agent (default 24, capped at 64).
# EVALUATION_AGENT_MAX_ITERATIONS=24
# Log each LangChain tool step — default on; set to 0 to disable.
# EVALUATION_LOG_AGENT_STEPS=0
# Log full evaluation LLM input — default on; set to 0 to disable.
# EVALUATION_LOG_COMPLETE_INPUT=0

# Sampling temperature for rubric evaluation (JSON chat). Default 0.4 if unset or non-numeric; not clamped.
# LLM_EVAL_TEMPERATURE=0.4

# --- Remote STT chunking (optional) ---
# REMOTE_STT_MAX_CHUNK_BYTES=

# --- Local STT (only if STT_PROVIDER=local) ---
# WHISPER_MODEL=base
# LOCAL_WHISPER_EXECUTABLE=whisper
# LOCAL_WHISPER_MAX_CHUNK_BYTES=

# --- HTTP API: frame extraction rate for video jobs ---
VIDEO_JOB_FRAME_FPS=2

# --- pipeline CLI / smoke (optional) ---
# VIDEO_PATH=
# VIDEO_EXTRACT_FPS=2
# VIDEO_MAX_DURATION_SEC=

# --- Pipeline tuning (optional) ---
# EDITOR_ROI_PAD_LEFT_PX=24
# FRAME_OCR_CONCURRENCY=8

# --- Google Gemini Live (optional voice interviewer over WebSocket) ---
# When GEMINI_API_KEY is set, clients can open ws(s)://<HOST>:<PORT>/api/live-sessions/<sessionId>/realtime while session is ACTIVE.
# GEMINI_LIVE_MODEL must be a model that supports the Live API (bidiGenerateContent), not a generic Flash id.
# Docs: https://ai.google.dev/gemini-api/docs/live-api/get-started-sdk
# Examples (pick one that your API key can access; names change over time):
#   gemini-2.5-flash-native-audio-preview-12-2025
#   gemini-3.1-flash-live-preview
# GEMINI_API_KEY=
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
#
# If the session used Gemini Live, post-process prefers `gemini-audio/realtime-transcriptions.jsonl` (API input/output transcription) over local STT and skips SRT/diarization — unless WhisperX is the SRT/diarization provider (see below), in which case Gemini realtime is skipped and one WhisperX pass supplies transcript + SRT + speaker labels.
# Sessions created with `liveInterviewerEnabled: false` never use that path (offline STT only).
# LIVE_SESSION_FORCE_WHISPER_STT=1

# --- SRT / speaker diarization (live session post-process) ---
# Default when unset is OpenAI semantic labeling. Requires STT + OpenAI or Anthropic for labeling.
# DIARIZATION_PROVIDER=openai
#
# Acoustic diarization (WhisperX + pyannote; requires HF token + pip install whisperx torch):
# DIARIZATION_PROVIDER=whisperx
# SRT_GENERATOR_PROVIDER=whisperx   # same effect if DIARIZATION_PROVIDER unset (SRT_* wins when set)
#
# Hugging Face token for WhisperX/pyannote (use HF_TOKEN, or HUGGING_FACE_HUB_TOKEN — huggingface_hub reads both):
# 1) Create a token: https://huggingface.co/settings/tokens
#    - Fine-grained: you MUST allow gated Hub downloads or you get HTTP 403, e.g. "Please enable access to public
#      gated repositories in your fine-grained token settings". Enable read access to public gated repos (or use a
#      classic token with Read scope, which is simpler for pyannote).
#    - Classic: "Read" scope is enough for downloading models.
# 2) While logged in as the same user, accept the model agreements (gated downloads fail until you do):
#    - https://huggingface.co/pyannote/speaker-diarization-3.1
#    - https://huggingface.co/pyannote/segmentation-3.0
#    (Accept any other pyannote links WhisperX prints if a download still fails.)
HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=   # optional alternative to HF_TOKEN for huggingface_hub
#
# Do not set SRT_GENERATOR_PROVIDER=none or DIARIZATION_PROVIDER=none — the server requires a diarization/SRT provider.
# DIARIZATION_PROVIDER=openai_semantic  # same as openai
# DIARIZATION_PYTHON=python3
# WHISPER_MODEL=base
# WHISPERX_DEVICE=cpu
# WHISPERX_COMPUTE_TYPE=int8
# WHISPERX_BATCH_SIZE=8
# Diarization min/max speakers (1–2) are hardcoded in scripts/diarize_dialogue_whisperx.py.
# DIARIZATION_TIMEOUT_MS=3600000
#
# WhisperX (`DIARIZATION_PROVIDER`/`SRT_GENERATOR_PROVIDER=whisperx`): with 2+ speakers, the server maps SPEAKER_xx → INTERVIEWER/INTERVIEWEE via LlmClientFactory (`LLM_PROVIDER`).

# --- HTTP server ---
PORT=3001
HOST=127.0.0.1
# LOG_LEVEL=info   # fatal | error | warn | info | debug | trace | silent (Pino / Fastify)

# --- Database (optional) ---
# Default URL is set in prisma/schema.prisma (SQLite under server/data/).
# If you override DATABASE_URL, prefer a single connection, e.g.:
# DATABASE_URL="file:./data/app.db?connection_limit=1"
# Avoid opening the same SQLite file in Prisma Studio + dev server + `prisma db push` at once, or you may see P1008 timeouts.
# Wipe DB + live session files and reapply schema (testing / breaking schema changes): `npm run db:reset` (stop the server first).
