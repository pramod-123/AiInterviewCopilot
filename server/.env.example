# Copy to .env and fill in values. Never commit .env.
#
# Optional: the Chrome extension “Server config” page (or PUT /api/app-config) writes
# server/data/app-runtime-config.json — non-empty fields there override these env vars at runtime
# for the voice WebSocket, evaluation LLM, and remote STT. Commit that file only if you intend to
# share non-secret defaults; it often contains API keys.

# --- Server logging (Winston + Fastify) ---
# LOG_LEVEL=info
# Shorthand for debug when LOG_LEVEL is unset: LOG_DEBUG=1
# Hourly JSON log files under ./logs (winston-daily-rotate-file): LOG_FILE_ENABLED=1
# LOG_DIR=logs

# --- OpenAI (remote STT, OpenAI-backed evaluation) ---
OPENAI_API_KEY=
OPENAI_MODEL_ID=gpt-5.4
# Remote Whisper (audio.transcriptions) uses whisper-1 in code — not OPENAI_MODEL_ID.
#
# Live voice interviewer WebSocket (`/api/live-sessions/:id/realtime`): default is Gemini (`LIVE_REALTIME_PROVIDER` unset or `gemini`).
# For OpenAI Realtime upstream, set all of the following (see OpenAI Realtime API docs for current model ids):
# LIVE_REALTIME_PROVIDER=openai
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
# OPENAI_REALTIME_VOICE=alloy

# Optional: retry tuning for OpenAI STT HTTP client
# OPENAI_STT_MAX_RETRIES=
# OPENAI_STT_RETRY_BASE_MS=

# --- Anthropic (only if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-opus-4-6

# --- Providers ---
# Speech-to-text is always the local OpenAI Whisper **Python** CLI.
# Model: `whisperModel` in app-runtime-config.json (Server config UI) overrides WHISPER_MODEL when set; else WHISPER_MODEL (or LOCAL_WHISPER_MODEL / WHISPERX_MODEL); default `base` if unset. UI choices come from `whisperModelOptions` in that file, falling back to `data/app-runtime-config.defaults.json` when omitted.
# Evaluator: llm (one-shot JSON) | single-agent (LangChain tool agent)
EVALUATION_PROVIDER=single-agent
# App LLM vendor (evaluation, LlmClientFactory.create): openai | anthropic | gemini
LLM_PROVIDER=openai
# Max tool+LLM turns for the agent (default 24, capped at 64).
# EVALUATION_AGENT_MAX_ITERATIONS=24
# Log each LangChain tool step — default on; set to 0 to disable.
# EVALUATION_LOG_AGENT_STEPS=0
# Log full evaluation LLM input — default on; set to 0 to disable.
# EVALUATION_LOG_COMPLETE_INPUT=0
# Single-agent only: log entire tool return JSON per step (default truncates at 6000 chars). Needs EVALUATION_LOG_AGENT_STEPS on.
# EVALUATION_LOG_FULL_TOOL_OBSERVATIONS=1
# Or set a custom cap (0 or -1 = unlimited like above).
# EVALUATION_AGENT_OBSERVATION_PREVIEW_CHARS=12000

# Sampling temperature for rubric evaluation (JSON chat). Default 0.4 if unset or non-numeric; not clamped.
# LLM_EVAL_TEMPERATURE=0.4

# --- Remote STT chunking (optional) ---
# REMOTE_STT_MAX_CHUNK_BYTES=

# --- Local STT (Whisper CLI) ---
# WHISPER_MODEL=base
# LOCAL_WHISPER_EXECUTABLE=whisper
# LOCAL_WHISPER_MAX_CHUNK_BYTES=

# --- Google Gemini Live (optional voice interviewer over WebSocket) ---
# When GEMINI_API_KEY is set, clients can open ws(s)://<HOST>:<PORT>/api/live-sessions/<sessionId>/realtime while session is ACTIVE.
# GEMINI_LIVE_MODEL must be a model that supports the Live API (bidiGenerateContent), not a generic Flash id.
# Docs: https://ai.google.dev/gemini-api/docs/live-api/get-started-sdk
# Examples (pick one that your API key can access; names change over time):
#   gemini-2.5-flash-native-audio-preview-12-2025
#   gemini-3.1-flash-live-preview
# GEMINI_API_KEY=
# Text/chat model when LLM_PROVIDER=gemini (LlmClientFactory / evaluation; not the Live voice model):
# GEMINI_MODEL_ID=gemini-2.0-flash
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# Optional prebuilt voice for Live output (`speechConfig`); can also set `geminiLiveVoice` in app-runtime-config.json.
# GEMINI_LIVE_VOICE=Puck
# Live always requests thought summaries (`thinkingConfig.includeThoughts`). Server maps thoughts to `modelThought` (logs + extension UI log line `Thought:`).
# Live connects with API v1alpha and proactive audio enabled (model may stay silent on irrelevant input; Google documents this for 2.5 Flash Live, not 3.1).
#
# When `liveInterviewerEnabled` is true, post-process loads `live-bridge-transcription/realtime-transcriptions.jsonl` first and
# builds transcript + `post-process/transcript.srt` from that. Local STT is skipped unless `LIVE_SESSION_FORCE_WHISPER_STT=1`.
# If no realtime rows exist, the pipeline uses local or remote STT on tab/mic `audio.wav` only (no LLM speaker labeling).
# Sessions created with `liveInterviewerEnabled: false` never use the realtime path (offline STT only).
# LIVE_SESSION_FORCE_WHISPER_STT=1

# --- HTTP server ---
PORT=3001
HOST=127.0.0.1
# LOG_LEVEL=info   # fatal | error | warn | info | debug | trace | silent (Pino / Fastify)

# --- Database (optional) ---
# Default URL is set in prisma/schema.prisma (SQLite under server/data/).
# If you override DATABASE_URL, prefer a single connection, e.g.:
# DATABASE_URL="file:./data/app.db?connection_limit=1"
# Avoid opening the same SQLite file in Prisma Studio + dev server + `prisma db push` at once, or you may see P1008 timeouts.
# Wipe DB + live session files and reapply schema (testing / breaking schema changes): `npm run db:reset` (stop the server first).
