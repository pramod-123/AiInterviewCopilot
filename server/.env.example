# Loaded automatically by `src/index.ts` and `prisma.config.ts` via dotenv (before DB / HTTP bind).
# Non-empty values in `server/.app-runtime-config.json` override these for the same logical settings:
#   listenHost   → HOST
#   listenPort   → PORT
#   databaseUrl  → DATABASE_URL
#
# Other keys in this file are also applied to `process.env` for the server process (use runtime JSON
# for secrets you prefer not to keep here).

HOST=127.0.0.1
PORT=3001
# SQLite / LibSQL (use an absolute file URL in production installs if you prefer):
DATABASE_URL=file:./data/app.db
# Example absolute URL:
# DATABASE_URL=file:/absolute/path/to/data/app.db

# JSON logs under ./logs (hourly rotation). Set to 0/false/no/off to disable file output only.
# LOG_FILE_ENABLED=0
# LOG_DIR=logs

# Local Ollama (when llmProvider / LLM_PROVIDER=ollama). No API key.
# OLLAMA_MODEL_ID=llama3.2
# OLLAMA_BASE_URL=http://127.0.0.1:11434
